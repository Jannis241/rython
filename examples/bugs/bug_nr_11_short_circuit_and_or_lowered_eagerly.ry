fn rhs_true() bool {
    return true;
}

fn rhs_false() bool {
    return false;
}

fn and_case(left: bool) bool {
    // Bug: `and` must be short-circuiting. Current IR lowers this as an eager
    // binary And after evaluating rhs_true().
    return left and rhs_true();
}

fn or_case(left: bool) bool {
    // Bug: `or` must be short-circuiting. Current IR lowers this as an eager
    // binary Or after evaluating rhs_false().
    return left or rhs_false();
}
