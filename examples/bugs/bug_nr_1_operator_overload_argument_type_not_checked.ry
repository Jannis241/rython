struct Box {
    value: int,

    fn operator + add(this, rhs: int) int {
        return this.value + rhs;
    }
}

fn main() int {
    let b: Box = Box { value: 1 };

    // Bug: this should be rejected because rhs expects int, not bool.
    // Current IR codegen accepts it and emits a mismatched call to Box_add.
    return b + true;
}
