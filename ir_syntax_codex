############################################################
# 40. IR-Builder im Compiler
############################################################

Ein IR-Codegenerator braucht ungefähr:

    current_function
    current_block
    temp_counter
    label_counter
    symbol_table
    break_targets
    continue_targets

Pseudo-Code:

    new_temp(type):
        name = "%tmp" + temp_counter
        temp_counter += 1
        return name

    new_label(prefix):
        name = prefix + "_" + label_counter
        label_counter += 1
        return name

    emit(instruction):
        current_block.instructions.push(instruction)


############################################################
# 41. lower_expr Beispiel
############################################################

Pseudo-Code:

    lower_expr(expr) -> IRValue {
        match expr {
            IntLiteral(value) => {
                tmp = new_temp(i64)
                emit(tmp + " = const.i64 " + value)
                return tmp
            }

            Ident(name) => {
                symbol = symbol_table.lookup(name)
                tmp = new_temp(symbol.type)
                emit(tmp + " = load." + symbol.type + " " + symbol.addr)
                return tmp
            }

            Binary(left, "+", right) => {
                l = lower_expr(left)
                r = lower_expr(right)
                tmp = new_temp(l.type)
                emit(tmp + " = add." + l.type + " " + l + ", " + r)
                return tmp
            }
        }
    }


############################################################
# 42. lower_stmt Beispiel
############################################################

Pseudo-Code:

    lower_stmt(stmt) {
        match stmt {
            Let(name, type, expr) => {
                ir_type = lower_type(type)
                addr = "%" + name + ".addr"
                emit(addr + ": ptr<" + ir_type + "> = alloca " + ir_type)

                value = lower_expr(expr)
                emit("store." + ir_type + " " + value + ", " + addr)

                symbol_table.insert(name, ir_type, addr)
            }

            Assign(name, expr) => {
                symbol = symbol_table.lookup(name)
                value = lower_expr(expr)
                emit("store." + symbol.type + " " + value + ", " + symbol.addr)
            }

            Return(expr) => {
                value = lower_expr(expr)
                emit("ret " + value)
            }
        }
    }


############################################################
# 43. Beispiel kompletter Source -> IR
############################################################

Source:

    fn main() int {
        let x: int = 5;
        x += 3;

        if x == 8 {
            return x;
        } else {
            return 0;
        }
    }

IR:

    module main

    fn @main() -> i64 {
    entry:
        %x.addr: ptr<i64> = alloca i64

        %tmp0: i64 = const.i64 5
        store.i64 %tmp0, %x.addr

        %old0: i64 = load.i64 %x.addr
        %tmp1: i64 = const.i64 3
        %new0: i64 = add.i64 %old0, %tmp1
        store.i64 %new0, %x.addr

        %x0: i64 = load.i64 %x.addr
        %tmp2: i64 = const.i64 8
        %cond0: bool = eq.i64 %x0, %tmp2
        br %cond0, label if_true_0, label if_false_0

    if_true_0:
        %x1: i64 = load.i64 %x.addr
        ret %x1

    if_false_0:
        %tmp3: i64 = const.i64 0
        ret %tmp3
    }


############################################################
# 44. Wichtigste Regeln zusammengefasst
############################################################

1. Alles Komplexe wird in kleine Schritte zerlegt.

2. Jede Expression gibt einen temporären Wert zurück.

3. Lokale Variablen haben eine Adresse:
       %x.addr

4. Um den Wert einer Variable zu lesen:
       load

5. Um eine Variable zu ändern:
       store

6. if/while/loop werden zu Labels und Sprüngen.

7. Methoden werden zu normalen Funktionen.

8. Structs sind nur Layout-Informationen.

9. Generics werden vor der Low-IR zu konkreten Typen gemacht.

10. Traits werden vor der Low-IR zu konkreten Funktionsaufrufen aufgelöst.

11. Assembly kennt keine structs, generics oder traits.
    Die IR hilft, diese Dinge vorher zu einfachen Speicherzugriffen und calls zu machen.


